<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to the Shipfide Team</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1f2937;">
    <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f3f4f6; padding: 40px 0;">
        <tr>
            <td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03); overflow: hidden;">
                    <!-- Header Accent -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%); height: 8px;"></td>
                    </tr>
                    
                    <!-- Content Body -->
                    <tr>
                        <td style="padding: 40px 48px;">
                            <!-- Logo / Brand -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 28px;">
                                <tr>
                                    <td>
                                        <span style="font-size: 24px; font-weight: 800; letter-spacing: -0.5px; color: #2563eb;">Shipfide</span>
                                    </td>
                                </tr>
                            </table>

                            <!-- Title -->
                            <h1 style="margin: 0 0 16px 0; font-size: 24px; font-weight: 700; color: #111827; letter-spacing: -0.2px;">Welcome to the Shipfide Team!</h1>
                            
                            <!-- Salutation -->
                            <p style="margin: 0 0 20px 0; font-size: 16px; line-height: 24px; color: #374151;">
                                Hello <% .Name %>,
                            </p>
                            
                            <!-- Introduction -->
                            <p style="margin: 0 0 24px 0; font-size: 16px; line-height: 24px; color: #4b5563;">
                                Your admin account has been created by the super administrator. You can now log into the Shipfide admin portal using the credentials provided below:
                            </p>

                            <!-- Credentials Box -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 24px; background-color: #f9fafb; border: 1px solid #e5e7eb; border-radius: 8px; padding: 20px;">
                                <tr>
                                    <td style="padding-bottom: 8px;">
                                        <strong style="color: #4b5563; font-size: 14px;">Email Address:</strong>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-bottom: 16px; font-size: 16px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; color: #111827;">
                                        <% .Email %>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="padding-bottom: 8px;">
                                        <strong style="color: #4b5563; font-size: 14px;">Temporary Password:</strong>
                                    </td>
                                </tr>
                                <tr>
                                    <td style="font-size: 16px; font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; color: #111827; letter-spacing: 0.5px;">
                                        <% .Password %>
                                    </td>
                                </tr>
                            </table>

                            <!-- Important Note about Password Change -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 32px; background-color: #eff6ff; border-left: 4px solid #3b82f6; border-radius: 4px; padding: 16px;">
                                <tr>
                                    <td style="font-size: 14px; line-height: 20px; color: #1e3a8a;">
                                        <strong>⚠️ Security Requirement:</strong> For security reasons, you will be required to change this temporary password immediately upon your first login.
                                    </td>
                                </tr>
                            </table>

                            <!-- Action Button -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 32px;">
                                <tr>
                                    <td align="center">
                                        <a href="<% .LoginLink %>" target="_blank" style="display: inline-block; background-color: #2563eb; color: #ffffff; font-weight: 600; font-size: 16px; padding: 12px 32px; text-decoration: none; border-radius: 6px; box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);">Go to Login</a>
                                    </td>
                                </tr>
                            </table>

                            <hr style="border: 0; border-top: 1px solid #f3f4f6; margin: 0 0 24px 0;">

                            <!-- Footer note -->
                            <p style="margin: 0; font-size: 13px; line-height: 18px; color: #9ca3af;">
                                If you did not expect this invitation or have questions, please reach out to your system administrator.
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Bottom Footer -->
                    <tr>
                        <td align="center" style="background-color: #f9fafb; padding: 24px 48px; border-top: 1px solid #f3f4f6;">
                            <p style="margin: 0; font-size: 12px; line-height: 16px; color: #9ca3af; text-align: center;">
                                © 2026 Shipfide Inc. All rights reserved.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>

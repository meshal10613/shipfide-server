<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reset Your Password</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f3f4f6; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1f2937;">
    <table border="0" cellpadding="0" cellspacing="0" width="100%" style="background-color: #f3f4f6; padding: 40px 0;">
        <tr>
            <td align="center">
                <table border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; background-color: #ffffff; border-radius: 12px; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03); overflow: hidden;">
                    <!-- Header Accent -->
                    <tr>
                        <td style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); height: 8px;"></td>
                    </tr>
                    
                    <!-- Content Body -->
                    <tr>
                        <td style="padding: 40px 48px;">
                            <!-- Logo / Brand -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 28px;">
                                <tr>
                                    <td>
                                        <span style="font-size: 24px; font-weight: 800; letter-spacing: -0.5px; color: #dc2626;">Shipfide</span>
                                    </td>
                                </tr>
                            </table>

                            <!-- Title -->
                            <h1 style="margin: 0 0 16px 0; font-size: 24px; font-weight: 700; color: #111827; letter-spacing: -0.2px;">Reset your password</h1>
                            
                            <!-- Salutation -->
                            <p style="margin: 0 0 20px 0; font-size: 16px; line-height: 24px; color: #374151;">
                                Hello <% .Name %>,
                            </p>
                            
                            <!-- Introduction -->
                            <p style="margin: 0 0 32px 0; font-size: 16px; line-height: 24px; color: #4b5563;">
                                We received a request to reset the password for your Shipfide account. Please enter the following OTP (One-Time Password) code on the password reset page to choose a new password:
                            </p>

                            <!-- OTP Box -->
                            <table border="0" cellpadding="0" cellspacing="0" width="100%" style="margin-bottom: 32px;">
                                <tr>
                                    <td align="center" style="background-color: #fdf2f2; border: 1px solid #fecaca; border-radius: 8px; padding: 20px 0;">
                                        <span style="font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace; font-size: 36px; font-weight: 800; letter-spacing: 6px; color: #991b1b; margin-left: 6px;"><% .OTP %></span>
                                    </td>
                                </tr>
                            </table>

                            <!-- Disclaimer / Expiration -->
                            <p style="margin: 0 0 32px 0; font-size: 14px; line-height: 20px; color: #6b7280; font-style: italic;">
                                * This reset code is valid for 15 minutes. If you did not request a password reset, you can safely ignore this email; your password will remain unchanged.
                            </p>

                            <hr style="border: 0; border-top: 1px solid #f3f4f6; margin: 0 0 24px 0;">

                            <!-- Footer note -->
                            <p style="margin: 0; font-size: 13px; line-height: 18px; color: #9ca3af;">
                                If you are having issues resetting your password, please contact our support team.
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Bottom Footer -->
                    <tr>
                        <td align="center" style="background-color: #f9fafb; padding: 24px 48px; border-top: 1px solid #f3f4f6;">
                            <p style="margin: 0; font-size: 12px; line-height: 16px; color: #9ca3af; text-align: center;">
                                © 2026 Shipfide Inc. All rights reserved.
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
